# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com/
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AZURE_OPENAI_EMBEDDING_API_VERSION=2024-10-01-preview

# Azure Database for PostgreSQL Configuration
AZURE_POSTGRESQL_HOST=YOUR-SERVER-NAME.postgres.database.windows.net
AZURE_POSTGRESQL_DATABASE=YOUR-DATABASE-NAME
AZURE_POSTGRESQL_PORT=5432
AZURE_POSTGRESQL_SSL=true

# Data Configuration
DATA_FILE=../data/HotelsData_toCosmosDB.JSON
DATA_FILE_WITH_VECTORS=../data/HotelsData_toCosmosDB_Vector.json
EMBEDDED_FIELD=contentVector
EMBEDDING_DIMENSIONS=1536

# Batch Configuration
LOAD_SIZE_BATCH=100
