{
  "name": "cosmos-nosql-vector-search-typescript",
  "version": "1.0.0",
  "description": "Samples for Cosmos DB NoSQL vector search",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start:embed": "node --env-file .env dist/create-embeddings.js",
